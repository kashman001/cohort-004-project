{
  "name": "cadence-course-platform",
  "private": true,
  "description": "An awesome horse platform",
  "type": "module",
  "scripts": {
    "cherry-pick": "ai-hero-cli cherry-pick --branch=live-run-through --upstream=https://github.com/ai-hero-dev/cohort-004-project.git",
    "reset": "ai-hero-cli reset --branch=live-run-through --upstream=https://github.com/ai-hero-dev/cohort-004-project.git",
    "pull": "ai-hero-cli pull --upstream=https://github.com/ai-hero-dev/cohort-004-project.git",
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate": "drizzle-kit migrate",
    "loc": "git ls-files | grep -vE '(lock|.db|_snapshot.json)' | xargs wc -l"
  },
